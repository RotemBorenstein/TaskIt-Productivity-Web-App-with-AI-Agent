# Django runtime
DJANGO_ENV=development
DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
ENABLE_PUBLIC_SIGNUP=True

# Database (PostgreSQL)
DB_NAME=taskit_db
DB_USER=taskit_user
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=prefer

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_SSL_CERT_REQS=CERT_NONE

# HTTPS/proxy behavior (production)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# AI / integrations
OPENAI_API_KEY=
EMAIL_TOKEN_ENCRYPTION_KEY=
EMAIL_SYNC_RETENTION_DAYS=30
EMAIL_SYNC_MAX_MESSAGES_PER_RUN=20
EMAIL_SUGGESTION_CONFIDENCE_THRESHOLD=0.65
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# Notifications
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
DEFAULT_FROM_EMAIL=TaskIt <notifications@example.com>
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_API_BASE_URL=https://api.telegram.org
